{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Codox",
  "version": "0.4.0",
  "identifier": "io.github.lotfy14.codox",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE5MkI0QkE2NUJCRUVFRgpSV1R2N3J0bHVyU1NBZm9QQTQ0dGh6UnVmSXlaKytmampjS2FselJjK3VXQ2tid0Y0UVh0NWNaLwo=",
      "endpoints": [
        "https://github.com/Lotfy14/Codox/releases/latest/download/latest.json"
      ]
    }
  },
  "app": {
    "windows": [
      {
        "title": "Codox",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": null
    }
  }
}
